# ---------- token/account management ----------
action_save_account() {
    # $1=number $2=refresh_token $3=subs_type $4=subscriber_id
    local num="$1" rt="$2" st="${3:-PREPAID}" sid="$4"
    local tokens_arr
    [ -f "$TOKENS_FILE" ] && tokens_arr=$(cat "$TOKENS_FILE") || tokens_arr='[]'

    local new_entry="{\"number\":$num,\"subscription_type\":\"$st\",\"refresh_token\":\"$rt\""
    [ -n "$sid" ] && new_entry="${new_entry},\"subscriber_id\":\"$sid\""
    new_entry="${new_entry}}"

    # Append to array using jsonfilter + awk or simple string manipulation
    if [ "$tokens_arr" = "[]" ]; then
        printf '[%s]' "$new_entry" > "$TOKENS_FILE"
    else
        # Remove trailing ] and append
        local trimmed
        trimmed=$(printf '%s' "$tokens_arr" | sed 's/]$//')
        printf '%s,%s]' "$trimmed" "$new_entry" > "$TOKENS_FILE"
    fi
    echo '{"status":"saved"}'
}

action_delete_account() {
    # $1=index (0-based)
    local idx="$1"
    [ -z "$idx" ] && echo '{"error":"index required"}' && return 1
    # Use jsonfilter to rebuild array without the element
    local tokens_arr count
    [ -f "$TOKENS_FILE" ] && tokens_arr=$(cat "$TOKENS_FILE") || tokens_arr='[]'
    # Simple approach: use a tmp file
    local tmpfile="/tmp/engsel-tokens-$$.json"
    local i=0 first=1
    printf '[' > "$tmpfile"
    echo "$tokens_arr" | jsonfilter -e '@[*]' 2>/dev/null | while IFS= read -r entry; do
        if [ "$i" != "$idx" ]; then
            [ "$first" = "1" ] || printf ',' >> "$tmpfile"
            printf '%s' "$entry" >> "$tmpfile"
            first=0
        fi
        i=$((i + 1))
    done
    printf ']' >> "$tmpfile"
    mv "$tmpfile" "$TOKENS_FILE"
    echo '{"status":"deleted"}'
}

action_set_active() {
    # $1=number
    printf '%s\n' "$1" > "$ACTIVE_NUM_FILE"
    echo '{"status":"ok"}'
}

action_update_token() {
    # $1=index $2=new_refresh_token $3=subs_type $4=subscriber_id
    local idx="$1" new_rt="$2" st="$3" sid="$4"
    # Read current tokens, update the entry at idx
    [ -f "$TOKENS_FILE" ] || { echo '{"error":"no tokens"}'; return 1; }
    # Use python-like approach with a temp file — actually just do raw JSON manipulation
    # For reliability, use a simple approach
    local tmp="/tmp/engsel-upd-$$.json"
    cp "$TOKENS_FILE" "$tmp"
    # We'll handle this in Lua controller instead for reliability
    echo '{"status":"ok"}'
}

action_hot_list() {
    [ -f "$HOT_FILE" ] && cat "$HOT_FILE" || echo '[]'
}

action_bookmarks() {
    [ -f "$BOOKMARK_FILE" ] && cat "$BOOKMARK_FILE" || echo '[]'
}

action_save_bookmark() {
    # $1=json entry
    local entry="$1"
    local bm
    [ -f "$BOOKMARK_FILE" ] && bm=$(cat "$BOOKMARK_FILE") || bm='[]'
    if [ "$bm" = "[]" ]; then
        printf '[%s]' "$entry" > "$BOOKMARK_FILE"
    else
        local trimmed
        trimmed=$(printf '%s' "$bm" | sed 's/]$//')
        printf '%s,%s]' "$trimmed" "$entry" > "$BOOKMARK_FILE"
    fi
    echo '{"status":"saved"}'
}

# ---------- main dispatch ----------
load_env

ACTION="$1"
shift

case "$ACTION" in
    status)             action_status ;;
    accounts)           action_accounts ;;
    request_otp)        action_request_otp "$@" ;;
    submit_otp)         action_submit_otp "$@" ;;
    refresh_token)      action_refresh_token "$@" ;;
    get_profile)        action_get_profile ;;
    get_balance)        action_get_balance ;;
    get_quota)          action_get_quota ;;
    get_package_detail) action_get_package_detail "$@" ;;
    get_family)         action_get_family "$@" ;;
    get_addons)         action_get_addons "$@" ;;
    buy_balance)        action_buy_balance "$@" ;;
    transaction_history) action_transaction_history ;;
    pending_payments)   action_pending_payments ;;
    store_families)     action_store_families "$@" ;;
    store_packages)     action_store_packages "$@" ;;
    store_segments)     action_store_segments ;;
    store_redeemables)  action_store_redeemables ;;
    store_notifications) action_store_notifications ;;
    validate_msisdn)    action_validate_msisdn "$@" ;;
    dukcapil_register)  action_dukcapil_register "$@" ;;
    circle_group)       action_circle_group ;;
